# -----------------------------------------------------------------------------
# Enterprise AI Operations Center - Local Development Environment Variables
# -----------------------------------------------------------------------------

# PostgreSQL Configuration
POSTGRES_USER=eaioc_admin
POSTGRES_PASSWORD=eaioc_secret_pass_local
POSTGRES_DB=eaioc_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=eaioc_redis_local
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# MinIO (S3) Configuration
MINIO_ROOT_USER=eaioc_minio_admin
MINIO_ROOT_PASSWORD=eaioc_minio_secret
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_REGION=us-east-1

# API Gateway & Services
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
RBAC_ENGINE_PORT=8002
AGENT_ENGINE_PORT=8003
RAG_SERVICE_PORT=8004

# JWT Secrets (Local Dev Only)
JWT_SECRET_KEY=local_dev_jwt_secret_do_not_use_in_prod
JWT_ALGORITHM=HS256

# External API Keys (Leave blank or fill for local testing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
